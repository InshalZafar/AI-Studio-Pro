# Copy this file to .env and adjust values as needed.
# You do NOT put OpenAI/Claude/Gemini/DeepSeek keys here -- those are entered
# by users inside the app (Settings -> API Key Manager) and stored in the database.

APP_NAME=AI Studio
ENV=development
DEBUG=true

# Generate a real random secret for anything beyond local dev, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_SECRET_IN_PRODUCTION_1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

DATABASE_URL=sqlite:///./ai_studio.db

FRONTEND_ORIGIN=http://localhost:3000

MAX_UPLOAD_MB=25
